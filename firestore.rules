rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isVerified() { return isAuth() && request.auth.token.email_verified == true; }

    // ── Users ───────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isAuth();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Products ────────────────────────────────────────
    match /products/{id} {
      allow read:   if true;
      allow write:  if isAdmin();

      // Reviews subcollection
      match /reviews/{reviewId} {
        allow read:   if true;
        allow create: if isVerified();
        allow update, delete: if isAdmin() ||
          (isAuth() && resource.data.userId == request.auth.uid);
      }
    }

    // ── Orders ──────────────────────────────────────────
    match /orders/{id} {
      allow read:   if isAdmin() ||
        (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isVerified();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Carts ───────────────────────────────────────────
    match /carts/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Coupons ─────────────────────────────────────────
    match /coupons/{id} {
      allow read:   if isAuth();   // validated on client for cart
      allow write:  if isAdmin();  // only admin can create/edit/delete
    }

    // ── Wishlists ───────────────────────────────────────
    match /wishlists/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Newsletter ──────────────────────────────────────
    match /newsletter/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
